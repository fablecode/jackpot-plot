<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:JackpotPlot.Desktop.UI.ViewModels"
             xmlns:menu="using:JackpotPlot.Desktop.UI.Models.Menu"
             mc:Ignorable="d" d:DesignWidth="220" d:DesignHeight="800"
             x:Class="JackpotPlot.Desktop.UI.Views.Components.SidebarView"
             x:DataType="vm:SidebarViewModel"
             Width="{Binding IsCollapsed, Converter={StaticResource BoolToWidthConverter}}">

    <Design.DataContext>
        <vm:SidebarViewModel />
    </Design.DataContext>

    <Border Background="{DynamicResource SidebarBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- Header with Logo -->
            <Border Grid.Row="0" 
                    Padding="16,12"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="JackpotPlot"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !IsCollapsed}" />

                    <Button Grid.Column="1"
                            Width="32"
                            Height="32"
                            Padding="6"
                            Command="{Binding ToggleSidebarCommand}"
                            ToolTip.Tip="Toggle Sidebar"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalAlignment="Center">
                        <PathIcon Data="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"
                                  Width="16"
                                  Height="16"
                                  Foreground="{DynamicResource TextSecondaryBrush}">
                            <PathIcon.RenderTransform>
                                <RotateTransform Angle="{Binding IsCollapsed, Converter={StaticResource BoolToAngleConverter}}" />
                            </PathIcon.RenderTransform>
                        </PathIcon>
                    </Button>
                </Grid>
            </Border>

            <!-- Scrollable Menu Content -->
            <ScrollViewer Grid.Row="1"
                          Padding="8,12">
                <ItemsControl ItemsSource="{Binding MenuItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="menu:MenuItemViewModel">
                            <StackPanel Margin="0,0,0,4">
                                <!-- Parent Menu Item -->
                                <Button Classes="menu-item-parent"
                                        Command="{Binding $parent[UserControl].((vm:SidebarViewModel)DataContext).ToggleMenuItemCommand}"
                                        CommandParameter="{Binding}"
                                        HorizontalContentAlignment="Stretch"
                                        Padding="8,6">
                                    <!-- When collapsed: show only centered dot -->
                                    <!-- When expanded: show dot + text + expand icon -->
                                    <Panel>
                                        <!-- Collapsed view: centered dot -->
                                        <TextBlock Text="●"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   IsVisible="{Binding $parent[UserControl].((vm:SidebarViewModel)DataContext).IsCollapsed}" />

                                        <!-- Expanded view: full layout -->
                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                              HorizontalAlignment="Stretch"
                                              IsVisible="{Binding !$parent[UserControl].((vm:SidebarViewModel)DataContext).IsCollapsed}">
                                            <TextBlock Grid.Column="0"
                                                       Text="●"
                                                       FontSize="12"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding IsExpanded, Converter={StaticResource ExpandIconConverter}}"
                                                       FontSize="12"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextMutedBrush}" />
                                        </Grid>
                                    </Panel>
                                </Button>

                                <!-- Child Menu Items (Accordion) - Hidden when sidebar collapsed -->
                                <ItemsControl ItemsSource="{Binding Children}"
                                              IsVisible="{Binding IsExpanded}"
                                              Margin="24,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="menu:MenuItemViewModel">
                                            <Button Classes="menu-item-child"
                                                    Classes.active="{Binding IsActive}"
                                                    Command="{Binding $parent[UserControl].((vm:SidebarViewModel)DataContext).NavigateCommand}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,2">
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <Border Grid.Column="0"
                                                            Width="6"
                                                            Height="6"
                                                            CornerRadius="3"
                                                            Margin="0,0,8,0"
                                                            Background="{DynamicResource TextMutedBrush}" />

                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Title}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Padding="12,8"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <TextBlock Text="v1.0.0"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsVisible="{Binding !IsCollapsed}" />
            </Border>
        </Grid>
    </Border>
</UserControl>
