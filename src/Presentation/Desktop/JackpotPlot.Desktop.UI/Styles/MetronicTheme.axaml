<Styles xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Include all Metronic theme resources -->
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/MetronicColors.axaml" />
                <ResourceInclude Source="/Styles/MetronicTypography.axaml" />
                <ResourceInclude Source="/Styles/MetronicSpacing.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>

    <!-- Base Application Styles -->

    <!-- Default TextBlock Style -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <!-- Default Window Style -->
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
    </Style>

    <!-- Default UserControl Style -->
    <Style Selector="UserControl">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
    </Style>

</Styles>
